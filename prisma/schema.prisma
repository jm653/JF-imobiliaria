generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id           String   @id @default(cuid())
  nome         String
  email        String   @unique
  senha        String
  telefone     String?
  avatarUrl    String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  perfilCliente  PerfilCliente?
  perfilCorretor PerfilCorretor?

  @@map("usuarios")
  contadorAcessos Int        @default(0)
  avaliacao       Avaliacao?
}

model PerfilCliente {
  id        String   @id @default(cuid())
  usuarioId String   @unique
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  criadoEm DateTime @default(now())

  pedidos PedidoImovel[]

  @@map("perfis_cliente")
}

model PerfilCorretor {
  id        String  @id @default(cuid())
  usuarioId String  @unique
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  creci      String?
  creditos   Int     @default(0)
  score      Float   @default(0)
  verificado Boolean @default(false)

  criadoEm DateTime @default(now())

  desbloqueios Desbloqueio[]
  imoveis      Imovel[]

  @@map("perfis_corretor")
}

model PedidoImovel {
  id        String        @id @default(cuid())
  clienteId String
  cliente   PerfilCliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  cidade              String
  bairro              String?
  valorMaximo         Int
  quartos             Int?
  banheiros           Int?
  garagem             Boolean @default(false)
  varanda             Boolean @default(false)
  quintal             Boolean @default(false)
  aceitaPet           Boolean @default(false)
  aceitaFinanciamento Boolean @default(false)
  descricaoLivre      String?

  status   String   @default("ativo")
  criadoEm DateTime @default(now())

  desbloqueios Desbloqueio[]

  @@map("pedidos_imovel")
}

model Desbloqueio {
  id         String         @id @default(cuid())
  pedidoId   String
  pedido     PedidoImovel   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  corretorId String
  corretor   PerfilCorretor @relation(fields: [corretorId], references: [id], onDelete: Cascade)

  creditosGastos Int      @default(10)
  estagio        String   @default("novo_lead")
  criadoEm       DateTime @default(now())

  mensagens Mensagem[]

  @@unique([pedidoId, corretorId])
  @@map("desbloqueios")
  dataVisita DateTime?
}

model Imovel {
  id         String         @id @default(cuid())
  corretorId String
  corretor   PerfilCorretor @relation(fields: [corretorId], references: [id], onDelete: Cascade)

  titulo    String
  cidade    String
  bairro    String?
  valor     Int
  quartos   Int?
  banheiros Int?
  garagem   Boolean @default(false)
  varanda   Boolean @default(false)
  quintal   Boolean @default(false)
  descricao String?

  status   String   @default("disponivel")
  criadoEm DateTime @default(now())

  @@map("imoveis")
}

model Mensagem {
  id            String      @id @default(cuid())
  desbloqueioId String
  desbloqueio   Desbloqueio @relation(fields: [desbloqueioId], references: [id], onDelete: Cascade)

  autorId  String
  conteudo String
  criadoEm DateTime @default(now())

  @@map("mensagens")
}

model Avaliacao {
  id        String   @id @default(cuid())
  usuarioId String   @unique
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  nota       Int
  comentario String?
  criadoEm   DateTime @default(now())

  @@map("avaliacoes")
}